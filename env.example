# =============================================
# frontline-clinical-rag Configuration
# Copy this file to .env and fill in your values
# =============================================

# --- Grok API (required) ---
FRONTLINE_GROK_API_KEY=your_grok_api_key_here

# --- Data locations ---
FRONTLINE_RAW_DATA_PATH=data/raw
# FRONTLINE_VECTOR_STORE_PATH=data/vector_store/faiss_index

# --- Chunking & Heading Detection (from ADR-002) ---
FRONTLINE_CHUNK_SIZE=800
FRONTLINE_CHUNK_OVERLAP=200
FRONTLINE_MAX_HEADING_LENGTH=140

# --- Embedding ---
FRONTLINE_EMBEDDING_MODEL=BAAI/bge-m3
FRONTLINE_EMBEDDING_DEVICE=cpu          # cpu | cuda | mps

# --- LLM Generation ---
FRONTLINE_GROK_MODEL=grok-3-beta
FRONTLINE_MAX_TOKENS=1024
FRONTLINE_TEMPERATURE=0.0

# --- Optional overrides (uncomment to change defaults) ---
# FRONTLINE_RAW_DATA_PATH=data/raw/test
# FRONTLINE_MAX_HEADING_LENGTH=120

# === Retrieval / Hybrid Retriever (ADR-004) ===
FRONTLINE_RETRIEVER_K_FINAL=5
FRONTLINE_RETRIEVER_K_DENSE=8
FRONTLINE_RETRIEVER_K_SPARSE=8
FRONTLINE_RETRIEVER_RRF_K=60
# FRONTLINE_RETRIEVER_BOOST_FACTORS={"warning": 1.7, "table": 1.25}
# FRONTLINE_RETRIEVER_SAFETY_WARNING_LEVELS=["black_box", "boxed_warning"]
# FRONTLINE_RETRIEVER_SAFETY_QUERY_TERMS=["warning", "contraindication", "black box", "adverse", "risk", "toxicity"]
FRONTLINE_RETRIEVER_SAFETY_DOWNWEIGHT_FACTOR=0.55