# =============================================
# frontline-clinical-rag Configuration
# Copy this file to .env and fill in your values
# =============================================

# --- Grok API (required) ---
FRONTLINE_GROK_API_KEY=your_grok_api_key_here

# --- Optional overrides (uncomment to change defaults) ---
# FRONTLINE_GROK_MODEL=grok-3-beta
# FRONTLINE_EMBEDDING_MODEL=BAAI/bge-m3
# FRONTLINE_VECTOR_STORE_PATH=data/vector_store/faiss_index
# FRONTLINE_CHUNK_SIZE=800
# FRONTLINE_CHUNK_OVERLAP=200
# FRONTLINE_MAX_TOKENS=1024
# FRONTLINE_TEMPERATURE=0.0

# Embedding device: "cpu" (safe), "cuda" (if available), or "mps" (Apple only)
FRONTLINE_EMBEDDING_DEVICE=cpu